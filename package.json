{
  "name": "bitresume",
  "version": "0.8.1-beta",
  "description": "Edytor CV z dwiema wersjami językowymi (PL/EN) w jednym szablonie JSON, zapisem na dysku i eksportem do PDF — aplikacja desktopowa (Electron) i wersja web.",
  "author": "Mateusz Starakiewicz",
  "private": true,
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "cross-env ELECTRON_DEV=1 concurrently -k \"next dev\" \"wait-on tcp:3000 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "cross-env ELECTRON=1 next build && electron-builder",
    "electron:pack": "cross-env ELECTRON=1 next build && electron-builder --dir"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "rcedit": "^5.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.cvbuldier.app",
    "productName": "BitResume",
    "directories": {
      "output": "dist",
      "buildResources": "packaging"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data/template.json",
        "to": "."
      },
      {
        "from": "LICENSE",
        "to": "."
      },
      {
        "from": "THIRD_PARTY_LICENSES.pl.txt",
        "to": "."
      },
      {
        "from": "THIRD_PARTY_LICENSES.en.txt",
        "to": "."
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true
    },
    "win": {
      "icon": "public/bitresume-certificate.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
